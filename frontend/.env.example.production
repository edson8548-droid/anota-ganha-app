# .env.production.template
# Copie este arquivo para .env.production e preencha com os valores reais
# NÃO commitar .env.production no git!

# URL do backend API (produção)
REACT_APP_BACKEND_URL=https://api.venpro.com.br

# Chave pública do Mercado Pago PRODUÇÃO
# Obter em: https://www.mercadopago.com.br/developers/panel/credentials
REACT_APP_MP_PUBLIC_KEY=

# Habilitar edição visual (deve ser false em produção)
REACT_APP_ENABLE_VISUAL_EDITS=false

# Analytics (opcional)
REACT_APP_POSTHOG_KEY=
REACT_APP_POSTHOG_HOST=https://us.i.posthog.com
