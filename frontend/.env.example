# URL do backend API
REACT_APP_BACKEND_URL=https://api.seudominio.com.br

# Chave pública do Mercado Pago (OBRIGATÓRIO para checkout funcionar)
REACT_APP_MP_PUBLIC_KEY=APP_USR-SEU-MERCADO-PAGO-KEY

# Habilitar edição visual (apenas para desenvolvimento)
REACT_APP_ENABLE_VISUAL_EDITS=false

# Analytics (opcional)
REACT_APP_POSTHOG_KEY=
REACT_APP_POSTHOG_HOST=https://us.i.posthog.com
