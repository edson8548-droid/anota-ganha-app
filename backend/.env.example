# ─── Banco de Dados ────────────────────────────────────────────────────────────
# Usar URL MongoDB Atlas (motor asyncio — NÃO usar URL PostgreSQL aqui)
MONGO_URL=mongodb+srv://usuario:senha@cluster.mongodb.net/database?retryWrites=true&w=majority
DB_NAME=anota_ganha

# ─── Segurança ─────────────────────────────────────────────────────────────────
# OBRIGATÓRIO: gerar com: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=GERAR_VALOR_FORTE_COM_SECRETS_TOKEN_HEX_32
RATE_LIMIT_ENABLED=true
# Opcional: salt para hashing de IDs nos logs de auditoria
AUDIT_HASH_SALT=venpro-audit

# ─── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://venpro.com.br
BACKEND_URL=https://api.venpro.com.br
CORS_ORIGINS=https://venpro.com.br,https://www.venpro.com.br,https://anota-ganha-app.web.app,https://anota-ganha-app.firebaseapp.com

# ─── Firebase Admin SDK ────────────────────────────────────────────────────────
# Obter em: Firebase Console > Configurações > Contas de serviço > Gerar nova chave privada
FIREBASE_PROJECT_ID=seu-project-id
FIREBASE_PRIVATE_KEY_ID=chave-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_PRIVADA\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@seu-project-id.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=seu-client-id
FIREBASE_STORAGE_BUCKET=seu-bucket.appspot.com

# ─── Asaas (Gateway de Pagamento) ─────────────────────────────────────────────
# Obter em: https://www.asaas.com/config/index (aba Integrações)
ASAAS_API_KEY=sua_chave_asaas_producao
ASAAS_BASE_URL=https://api.asaas.com/v3
# OBRIGATÓRIO para webhooks: definir token no painel Asaas e repetir aqui
# Asaas > Configurações > Integrações > Webhooks > Token de acesso
ASAAS_WEBHOOK_TOKEN=seu_token_webhook_asaas

# ─── SendGrid (Email) ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=seu_sendgrid_api_key
SENDER_EMAIL=suporte@venpro.com.br

# ─── Mercado Pago (desativado — manter vazio) ──────────────────────────────────
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=

# ─── IA ────────────────────────────────────────────────────────────────────────
AI_PROVIDER=groq
GROQ_API_KEY=seu_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (alternativa/complementar ao Groq para matching)
GEMINI_API_KEY=seu_gemini_api_key

# ─── Serper.dev (busca de imagens para vitrine) ────────────────────────────────
SERPER_API_KEY=seu_serper_api_key

# ─── Ambiente ──────────────────────────────────────────────────────────────────
# Definir como "production" no Render — ativa validações extras de webhook
APP_ENV=development
