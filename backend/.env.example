# Segurança
JWT_SECRET_KEY=seu_jwt_secret_super_seguro_aqui

# Mercado Pago
MP_ACCESS_TOKEN=seu_token_mercadopago_producao
MP_PUBLIC_KEY=sua_public_key_mercadopago

# SendGrid (Email)
SENDGRID_API_KEY=seu_sendgrid_api_key
