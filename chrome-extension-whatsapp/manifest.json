{
  "manifest_version": 3,
  "name": "Venpro — Carteira no WhatsApp",
  "version": "1.1.20",
  "description": "Envia ofertas para clientes via WhatsApp Web com sua campanha Venpro.",
  "permissions": ["activeTab", "scripting", "tabs", "storage", "sidePanel"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://venpro.com.br/*",
    "https://www.venpro.com.br/*",
    "https://api.venpro.com.br/*"
  ],
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://venpro.com.br/*",
        "https://www.venpro.com.br/*"
      ],
      "js": ["venpro-content.js"],
      "run_at": "document_idle"
    }
  ]
}
