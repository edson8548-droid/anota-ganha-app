rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function ownsExistingDoc() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function createsOwnDoc() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function keepsOwnership() {
      return signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    function userAdminFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny([
          'role',
          'license_key',
          'license_type',
          'trial_ends_at',
          'subscription',
          'isAdmin'
        ]);
    }

    function validUserCreateFields() {
      return request.resource.data.keys().hasOnly([
        'email',
        'name',
        'nome',
        'displayName',
        'cpf',
        'telefone',
        'role',
        'license_type',
        'trial_ends_at',
        'created_at',
        'updated_at'
      ]);
    }

    function validUserCreateValues() {
      return request.resource.data.role == 'user'
        && request.resource.data.license_type == 'trial'
        && request.resource.data.email is string
        && request.resource.data.cpf is string
        && request.resource.data.telefone is string;
    }

    function onlySafeUserProfileFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'name',
        'nome',
        'displayName',
        'telefone',
        'photoURL',
        'updated_at'
      ]);
    }

    match /users/{userId} {
      allow read: if isSelf(userId);
      allow create: if isSelf(userId)
        && validUserCreateFields()
        && validUserCreateValues();
      allow update: if isSelf(userId)
        && userAdminFieldsUnchanged()
        && onlySafeUserProfileFieldsChanged();
      allow delete: if false;
    }

    match /subscriptions/{userId} {
      allow read: if isSelf(userId);
      allow create, update: if isSelf(userId)
        && (!('userId' in request.resource.data) || request.resource.data.userId == userId);
      allow delete: if false;
    }

    match /campaigns/{campaignId} {
      allow read, delete: if ownsExistingDoc();
      allow update: if keepsOwnership();
      allow create: if createsOwnDoc();
    }

    match /clients/{clientId} {
      allow read, delete: if ownsExistingDoc();
      allow update: if keepsOwnership();
      allow create: if createsOwnDoc();
    }

    match /coupons/{couponId} {
      allow read, write: if false;
    }

    match /whatsapp_campaigns/{userId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
