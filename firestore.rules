rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function ownsExistingDoc() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function createsOwnDoc() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function keepsOwnership() {
      return signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    function userAdminFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny([
          'role',
          'license_key',
          'license_type',
          'trial_ends_at',
          'subscription',
          'isAdmin'
        ]);
    }

    function onlySafeUserProfileFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'name',
        'nome',
        'displayName',
        'photoURL',
        'updated_at'
      ]);
    }

    function validTrialSubscriptionExpire(userId) {
      return isSelf(userId)
        && resource.data.userId == userId
        && resource.data.planId == 'trial'
        && resource.data.status == 'trialing'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'updatedAt'
        ])
        && request.resource.data.userId == userId
        && request.resource.data.planId == 'trial'
        && request.resource.data.status == 'trial_expired';
    }

    match /users/{userId} {
      allow read: if isSelf(userId);
      allow create: if false;
      allow update: if isSelf(userId)
        && userAdminFieldsUnchanged()
        && onlySafeUserProfileFieldsChanged();
      allow delete: if false;
    }

    match /subscriptions/{userId} {
      allow read: if isSelf(userId);
      allow create: if false;
      allow update: if validTrialSubscriptionExpire(userId);
      allow delete: if false;
    }

    match /campaigns/{campaignId} {
      allow read, delete: if ownsExistingDoc();
      allow update: if keepsOwnership();
      allow create: if createsOwnDoc();
    }

    match /clients/{clientId} {
      allow read, delete: if ownsExistingDoc();
      allow update: if keepsOwnership();
      allow create: if createsOwnDoc();
    }

    match /coupons/{couponId} {
      allow read, write: if false;
    }

    match /whatsapp_campaigns/{userId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
