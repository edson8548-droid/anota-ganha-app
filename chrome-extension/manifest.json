{
  "manifest_version": 3,
  "name": "Venpro — Preencher Cotatudo",
  "version": "1.0.1",
  "description": "Preenche cotações no Cotatudo automaticamente com preços da sua tabela Venpro.",
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": [
    "https://www.cotatudo.com.br/*",
    "https://venpro.com.br/*",
    "https://www.venpro.com.br/*",
    "https://anota-ganha-app.web.app/*",
    "https://anota-ganha-app.firebaseapp.com/*",
    "https://api.venpro.com.br/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.cotatudo.com.br/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
