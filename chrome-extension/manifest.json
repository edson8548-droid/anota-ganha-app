{
  "manifest_version": 3,
  "name": "Venpro — Preencher Cotatudo",
  "version": "1.0.13",
  "description": "Preenche cotações no Cotatudo automaticamente com preços da sua tabela Venpro.",
  "permissions": ["activeTab", "scripting", "tabs", "storage", "sidePanel"],
  "host_permissions": [
    "https://cotatudo.com.br/*",
    "https://www.cotatudo.com.br/*",
    "https://venpro.com.br/*",
    "https://www.venpro.com.br/*",
    "https://anota-ganha-app.web.app/*",
    "https://anota-ganha-app.firebaseapp.com/*",
    "https://api.venpro.com.br/*"
  ],
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://cotatudo.com.br/*", "https://www.cotatudo.com.br/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    },
    {
      "matches": [
        "https://venpro.com.br/*",
        "https://www.venpro.com.br/*",
        "https://anota-ganha-app.web.app/*",
        "https://anota-ganha-app.firebaseapp.com/*"
      ],
      "js": ["venpro-content.js"],
      "run_at": "document_idle"
    }
  ]
}
