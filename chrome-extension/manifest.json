{
  "manifest_version": 3,
  "name": "Venpro — Preencher Cotação",
  "version": "1.0.82",
  "description": "Preenche cotações em portais compatíveis usando os preços das tabelas cadastradas no Venpro.",
  "minimum_chrome_version": "114",
  "homepage_url": "https://venpro.com.br",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://cotatudo.com.br/*",
    "https://www.cotatudo.com.br/*",
    "https://venpro.com.br/*",
    "https://www.venpro.com.br/*",
    "https://*.venpro.com.br/*",
    "https://anota-ganha-app.web.app/*",
    "https://anota-ganha-app.firebaseapp.com/*",
    "https://fornecedor.rpinfo.com.br/*",
    "https://rfd.net.br/*",
    "https://www.rfd.net.br/*",
    "https://*.rfd.net.br/*",
    "http://rfd.net.br/*",
    "http://www.rfd.net.br/*",
    "http://*.rfd.net.br/*",
    "https://infomagcotacao.com/*",
    "https://www.infomagcotacao.com/*",
    "https://cotacaonovo.intersolid.com.br/*",
    "http://cotacaonovo.intersolid.com.br/*",
    "https://*.intersolid.com.br/*",
    "http://*.intersolid.com.br/*",
    "https://cotacaoweb.smus.com.br/*",
    "http://cotacaoweb.smus.com.br/*",
    "https://catalog-32594.bubbleapps.io/*",
    "https://cotacao.hipcomerp.com.br/*",
    "http://cotacao.hipcomerp.com.br/*",
    "https://gepautomacao.dyndns.org/*",
    "http://gepautomacao.dyndns.org/*",
    "https://cotacao.estanciasupermercados.com.br/*",
    "http://cotacao.estanciasupermercados.com.br/*",
    "https://cotacao.sghost.com.br/*",
    "http://cotacao.sghost.com.br/*",
    "https://cotacao.hrtech.com.br/*",
    "http://cotacao.hrtech.com.br/*",
    "https://*.arius-web.harpocloud.com.br/*",
    "http://*.arius-web.harpocloud.com.br/*",
    "https://erp.bluesoft.com.br/*",
    "http://erp.bluesoft.com.br/*",
    "https://cg.jrsupermercados.com.br/*",
    "http://cg.jrsupermercados.com.br/*",
    "http://nafarmasl.ddns.net:8080/*",
    "https://cotacao.dobesone.emartim.com.br/*",
    "https://cotacao.syspanweb.com.br/*",
    "https://cotacao3.egestora.com.br/*",
    "http://200.160.111.171:8082/*",
    "http://bids.imperiumsolucoes.com/*",
    "https://bids.imperiumsolucoes.com/*",
    "https://sistemas.cotefacil.com/*",
    "https://www.cotacao.inplug.online/*",
    "https://api.venpro.com.br/*"
  ],
  "action": {
    "default_title": "Abrir Venpro — Preencher Cotação",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "smus-page-bridge.js"
      ],
      "matches": [
        "https://cotacaoweb.smus.com.br/*",
        "http://cotacaoweb.smus.com.br/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://cotacao.hipcomerp.com.br/*",
        "http://cotacao.hipcomerp.com.br/*"
      ],
      "js": [
        "hipcom-main-world.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.arius-web.harpocloud.com.br/*",
        "http://*.arius-web.harpocloud.com.br/*"
      ],
      "js": [
        "arius-main-world.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://erp.bluesoft.com.br/*",
        "http://erp.bluesoft.com.br/*"
      ],
      "js": [
        "bluesoft-main-world.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://cg.jrsupermercados.com.br/*",
        "http://cg.jrsupermercados.com.br/*"
      ],
      "js": [
        "guiacotacao-main-world.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://cotatudo.com.br/*",
        "https://www.cotatudo.com.br/*",
        "http://179.0.124.205/*",
        "https://fornecedor.rpinfo.com.br/*",
        "https://rfd.net.br/*",
        "https://www.rfd.net.br/*",
        "https://*.rfd.net.br/*",
        "http://rfd.net.br/*",
        "http://www.rfd.net.br/*",
        "http://*.rfd.net.br/*",
        "https://infomagcotacao.com/*",
        "https://www.infomagcotacao.com/*",
        "https://cotacaonovo.intersolid.com.br/*",
        "http://cotacaonovo.intersolid.com.br/*",
        "https://*.intersolid.com.br/*",
        "http://*.intersolid.com.br/*",
        "https://cotacaoweb.smus.com.br/*",
        "http://cotacaoweb.smus.com.br/*",
        "https://catalog-32594.bubbleapps.io/*",
        "https://cotacao.hipcomerp.com.br/*",
        "http://cotacao.hipcomerp.com.br/*",
        "https://gepautomacao.dyndns.org/*",
        "http://gepautomacao.dyndns.org/*",
        "https://cotacao.estanciasupermercados.com.br/*",
        "http://cotacao.estanciasupermercados.com.br/*",
        "https://cotacao.sghost.com.br/*",
        "http://cotacao.sghost.com.br/*",
        "https://cotacao.hrtech.com.br/*",
        "http://cotacao.hrtech.com.br/*",
        "https://*.arius-web.harpocloud.com.br/*",
        "http://*.arius-web.harpocloud.com.br/*",
        "https://erp.bluesoft.com.br/*",
        "http://erp.bluesoft.com.br/*",
        "https://cg.jrsupermercados.com.br/*",
        "http://cg.jrsupermercados.com.br/*",
        "http://nafarmasl.ddns.net:8080/*",
        "https://cotacao.dobesone.emartim.com.br/*",
        "https://cotacao.syspanweb.com.br/*",
        "https://cotacao3.egestora.com.br/*",
        "http://200.160.111.171:8082/Cotacao/*",
        "http://bids.imperiumsolucoes.com/*",
        "https://bids.imperiumsolucoes.com/*",
