        "https://venpro.com.br/demonstracao-extensao-cotacao.html",
        "https://www.venpro.com.br/demonstracao-extensao-cotacao.html"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    },
    {
      "matches": [
        "https://venpro.com.br/*",
        "https://www.venpro.com.br/*",
        "https://*.venpro.com.br/*",
        "https://anota-ganha-app.web.app/*",
        "https://anota-ganha-app.firebaseapp.com/*"
      ],
