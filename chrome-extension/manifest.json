{
  "manifest_version": 3,
  "name": "Venpro — Preencher Cotação",
  "version": "1.0.26",
  "description": "Preenchedor de cotações do Venpro para Cotatudo, VR Cotação, RP HUB, Rede de Fornecedores, Infomag Cotação, Intersolid Cotação e novos portais compatíveis.",
  "permissions": ["activeTab", "scripting", "tabs", "storage", "sidePanel"],
  "host_permissions": [
    "https://cotatudo.com.br/*",
    "https://www.cotatudo.com.br/*",
    "https://venpro.com.br/*",
    "https://www.venpro.com.br/*",
    "https://fornecedor.rpinfo.com.br/*",
    "https://rfd.net.br/*",
    "https://www.rfd.net.br/*",
    "https://*.rfd.net.br/*",
    "http://rfd.net.br/*",
    "http://www.rfd.net.br/*",
    "http://*.rfd.net.br/*",
    "https://infomagcotacao.com/*",
    "https://www.infomagcotacao.com/*",
    "https://cotacaonovo.intersolid.com.br/*",
    "http://cotacaonovo.intersolid.com.br/*",
    "https://*.intersolid.com.br/*",
    "http://*.intersolid.com.br/*",
    "https://api.venpro.com.br/*"
  ],
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://cotatudo.com.br/*",
        "https://www.cotatudo.com.br/*",
        "http://179.0.124.205/*",
        "https://fornecedor.rpinfo.com.br/*",
        "https://rfd.net.br/*",
        "https://www.rfd.net.br/*",
        "https://*.rfd.net.br/*",
        "http://rfd.net.br/*",
        "http://www.rfd.net.br/*",
        "http://*.rfd.net.br/*",
        "https://infomagcotacao.com/*",
        "https://www.infomagcotacao.com/*",
        "https://cotacaonovo.intersolid.com.br/*",
        "http://cotacaonovo.intersolid.com.br/*",
        "https://*.intersolid.com.br/*",
        "http://*.intersolid.com.br/*",
        "https://*/fornecedores/*/cotacao/*",
        "http://*/fornecedores/*/cotacao/*",
        "https://*/cotacao/*",
        "http://*/cotacao/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    },
    {
      "matches": [
        "https://venpro.com.br/*",
        "https://www.venpro.com.br/*"
      ],
      "js": ["venpro-content.js"],
      "run_at": "document_idle"
    }
  ]
}
